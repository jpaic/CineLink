# TMDB API Configuration
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_BASE_URL=https://api.themoviedb.org/3

# Frontend Configuration
# For local dev:
FRONTEND_ORIGIN=http://localhost:3000
# For Vercel production, set FRONTEND_ORIGIN to your Vercel URL:
# FRONTEND_ORIGIN=https://cinelink.vercel.app
# Or set FRONTEND_ORIGINS to a comma-separated list of allowed origins:
# FRONTEND_ORIGINS=http://localhost:3000,https://cinelink.vercel.app

# Server Configuration (for Vercel/production)
PORT=8000
