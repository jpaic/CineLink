# Frontend API Configuration
# For local development
NEXT_PUBLIC_API_URL=http://localhost:8000

# For production with Vercel
# if the backend is deployed in the same Vercel project, use the service prefix:
# NEXT_PUBLIC_API_URL=https://your-project.vercel.app/_/backend
# otherwise use the standalone backend hostname:
# NEXT_PUBLIC_API_URL=https://your-backend-url.com
